generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  moodEntries   MoodEntry[]
  aiInsights    AIInsight[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  spotifyAccessToken  String?
  spotifyRefreshToken String?
  spotifyTokenExpiry  DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model MoodEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  mood      Int
  note      String?
  tracks    Track[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Track {
  id          String    @id @default(cuid())
  entryId     String
  title       String
  artist      String
  albumCover  String?
  spotifyId   String?
  entry       MoodEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model AIInsight {
  id          String   @id @default(cuid())
  userId      String
  content     String
  periodStart DateTime
  periodEnd   DateTime
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}